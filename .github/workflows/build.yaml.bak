name: Build & Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

env:
  BUN_VERSION: "latest"
  ZIG_VERSION: "0.14.0"

jobs:
  build:
    strategy:
      fail-fast: false
      matrix:
        include:
          - os: ubuntu-latest
            artifact: tns-linux-x64
            cc: "zig cc -target x86_64-linux-gnu"
            cflags: "-shared -fPIC -O3"
            suffix: .so
            bun_target: ""

          - os: ubuntu-latest
            artifact: tns-linux-arm64
            cc: "zig cc -target aarch64-linux-gnu"
            cflags: "-shared -fPIC -O3"
            suffix: .so
            bun_target: bun-linux-arm64

          - os: macos-latest
            artifact: tns-macos-arm64
            cc: "cc"
            cflags: "-dynamiclib -O3"
            suffix: .dylib
            bun_target: ""

          - os: macos-latest
            artifact: tns-macos-x64
            cc: "cc -arch x86_64"
            cflags: "-dynamiclib -O3"
            suffix: .dylib
            bun_target: bun-darwin-x64

          - os: windows-latest
            artifact: tns-windows-x64
            cc: "zig cc -target x86_64-windows-gnu"
            cflags: "-shared -fPIC -O3"
            suffix: .dll
            bun_target: ""

    runs-on: ${{ matrix.os }}

    steps:
      - uses: actions/checkout@v7
        with:
          persist-credentials: false

      - name: Install Bun
        uses: oven-sh/setup-bun@v2.2.0
        with:
          bun-version: ${{ env.BUN_VERSION }}

      - name: Install Zig (Linux)
        if: runner.os == 'Linux'
        run: |
          curl -sL https://ziglang.org/download/${{ env.ZIG_VERSION }}/zig-linux-x86_64-${{ env.ZIG_VERSION }}.tar.xz | tar -xJ
          sudo mv zig-linux-x86_64-${{ env.ZIG_VERSION }} /usr/local/zig
          sudo ln -sf /usr/local/zig/zig /usr/local/bin/zig
          zig version

      - name: Install Zig (Windows)
        if: runner.os == 'Windows'
        shell: bash
        run: |
          curl -sL https://ziglang.org/download/${{ env.ZIG_VERSION }}/zig-windows-x86_64-${{ env.ZIG_VERSION }}.zip -o zig.zip
          unzip -q zig.zip
          mv zig-windows-x86_64-${{ env.ZIG_VERSION }} /c/zig
          echo "/c/zig" >> $GITHUB_PATH

      - name: Install dependencies
        run: bun install

      - name: Build FFI kernels
        shell: bash
        run: |
          PKG_DIR="release/${{ matrix.artifact }}"
          mkdir -p "$PKG_DIR"
          
          CC="${{ matrix.cc }}"
          CFLAGS="${{ matrix.cflags }}"
          SUFFIX="${{ matrix.suffix }}"
          
          echo "CC=$CC CFLAGS=$CFLAGS suffix=$SUFFIX"
          
          for pair in \
            "probability_ffi libtns_kernels" \
            "vector_ffi libtns_vectors" \
            "vector_full libtns_vector_full" \
            "batch_ops libtns_batch_ops" \
            "graph_ops libtns_graph_ops"; do
            src=$(echo "$pair" | cut -d' ' -f1)
            name=$(echo "$pair" | cut -d' ' -f2)
            echo "  ${name}${SUFFIX}"
            $CC $CFLAGS \
              -o "$PKG_DIR/${name}${SUFFIX}" \
              "mojo/kernels/c/${src}.c" -lm 2>&1 | grep -v "warning" || true
          done

      - name: Build Bun binary
        shell: bash
        run: |
          OUT="release/${{ matrix.artifact }}/tns-server"
          if [[ "${{ runner.os }}" == "Windows" ]]; then
            OUT="${OUT}.exe"
          fi
          
          BUN_TARGET="${{ matrix.bun_target }}"
          if [[ -n "$BUN_TARGET" ]]; then
            echo "Cross-compiling: $BUN_TARGET"
            bun build --compile --target "$BUN_TARGET" --outfile "$OUT" src/index.ts
          else
            echo "Native build"
            bun build --compile --outfile "$OUT" src/index.ts
          fi

      - name: Package
        shell: bash
        run: |
          PKG_DIR="release/${{ matrix.artifact }}"
          cp -r public/ "$PKG_DIR/" 2>/dev/null || true
          cp -r docs/ "$PKG_DIR/" 2>/dev/null || true
          cp .env.example "$PKG_DIR/" 2>/dev/null || true
          cp startgame.sh "$PKG_DIR/" 2>/dev/null || true
          cp README*.md "$PKG_DIR/" 2>/dev/null || true
          chmod +x "$PKG_DIR"/tns-server* 2>/dev/null || true
          chmod +x "$PKG_DIR"/startgame.sh 2>/dev/null || true
          
          echo "=== Package contents ==="
          ls -lh "$PKG_DIR/"
          
          cd release
          VERSION="${GITHUB_REF_NAME:-dev}"
          if [[ "${{ runner.os }}" == "Windows" ]]; then
            7z a ${{ matrix.artifact }}-${VERSION}.zip ${{ matrix.artifact }}/
          else
            tar -czf ${{ matrix.artifact }}-${VERSION}.tar.gz ${{ matrix.artifact }}/
          fi

      - uses: actions/upload-artifact@v7
        with:
          name: ${{ matrix.artifact }}
          path: release/${{ matrix.artifact }}-*

  release:
    needs: build
    runs-on: ubuntu-latest
    steps:
      - uses: actions/download-artifact@v7
        with:
          path: artifacts

      - uses: softprops/action-gh-release@v3
        with:
          tag_name: ${{ github.ref_name }}
          name: ${{ github.ref_name }}
          generate_release_notes: true
          files: |
            artifacts/**/*.tar.gz
            artifacts/**/*.zip
