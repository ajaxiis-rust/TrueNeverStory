# TrueNeverStory v0.10.0 — Environment Configuration
#
# This file is OPTIONAL. All settings can be configured via the web UI.
# Copy to .env and edit, or configure everything in Settings page.
#
# Priority: conf/settings.json > .env > defaults

# ─────────────────────────────────────────────
#  LLM Configuration (required for first run)
# ─────────────────────────────────────────────
# Point to any OpenAI-compatible API:
#   - Ollama:    http://localhost:11434/v1
#   - vLLM:      http://localhost:8000/v1
#   - OpenAI:    https://api.openai.com/v1
#   - LM Studio: http://localhost:1234/v1

WORLD_LLM_BASE_URL=http://localhost:11434/v1
WORLD_LLM_API_KEY=ollama
WORLD_LLM_MODEL=llama3

# ─────────────────────────────────────────────
#  Embedding (optional, for semantic search)
# ─────────────────────────────────────────────
# Leave empty to disable embedding features
WORLD_EMBEDDING_MODEL=
WORLD_EMBEDDING_BASE_URL=
WORLD_EMBEDDING_API_KEY=

# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
WORLD_SERVER_HOST=0.0.0.0
WORLD_SERVER_PORT=8000

# ─────────────────────────────────────────────
#  Authentication
# ─────────────────────────────────────────────
# Default password: changeme
# Change in Settings after first login
AUTH_PASSWORD=changeme

# ─────────────────────────────────────────────
#  Advanced (optional)
# ─────────────────────────────────────────────
WORLD_LLM_TIMEOUT=120
WORLD_LLM_MAX_TOKENS=4096
WORLD_LLM_TEMPERATURE=0.7
WORLD_LLM_MAX_RETRIES=3
WORLD_LLM_MAX_CONCURRENT=8
WORLD_DB_PATH=./world_db
WORLD_AUTO_HEAL=true
